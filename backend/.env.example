# Google Gemini API Key (free from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Encryption key for file storage (generate a strong random key)
ENCRYPTION_KEY=your-strong-encryption-key-min-32-chars!!

# Application settings
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
MAX_FILE_SIZE_MB=50
RATE_LIMIT_UPLOADS=30
RATE_LIMIT_CHAT=60

# Storage paths
STORAGE_PATH=./storage
CHROMA_PATH=./storage/chromadb
